<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="162.0" prefWidth="204.0" spacing="10" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.groupactivitycapstone.LoginController">
    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Attendance System" />

    <TextField fx:id="tfUsername" promptText="Username">
      <VBox.margin>
         <Insets left="10.0" right="10.0" />
      </VBox.margin></TextField>

    <PasswordField fx:id="pfPassword" promptText="Password">
      <VBox.margin>
         <Insets left="10.0" right="10.0" />
      </VBox.margin></PasswordField>

    <Button onAction="#handleLogin" text="Login" />

    <Label fx:id="lblMessage" text="" />
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>

</VBox>
