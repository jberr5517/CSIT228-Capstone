<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.groupactivitycapstone.StudentController">
    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Student Dashboard" />
    <HBox alignment="CENTER" spacing="10">
        <Button text="Time In" />
        <Button text="Time Out" />
    </HBox>
   <HBox alignment="TOP_CENTER" prefHeight="0.0" prefWidth="0.0">
      <children>
          <TextField minHeight="30.0" minWidth="0.0" prefHeight="30.0" prefWidth="271.0" promptText="Search here...">
            <HBox.margin>
               <Insets right="10.0" />
            </HBox.margin>
            <VBox.margin>
               <Insets />
            </VBox.margin>
         </TextField>
          <ComboBox promptText="Select Filter" />
      </children>
   </HBox>
    <TableView prefHeight="250" prefWidth="450">
        <columns>
            <TableColumn prefWidth="80" text="ID" />
            <TableColumn prefWidth="150" text="Name" />
            <TableColumn prefWidth="100" text="Time In" />
            <TableColumn prefWidth="100" text="Time Out" />
        </columns>
    </TableView>

</VBox>
