<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.attendance.RegisterController"
           prefWidth="440" prefHeight="580"
           style="-fx-background-color: #F0EEE8;">

    <VBox alignment="CENTER" spacing="0"
          maxWidth="360"
          style="-fx-background-color: white;
                 -fx-border-color: #D3D1C7;
                 -fx-border-width: 0.5;
                 -fx-border-radius: 12;
                 -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 16, 0, 0, 4);">

        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #2C2C2A;
                     -fx-background-radius: 12 12 0 0;
                     -fx-padding: 28 24 24 24;">
            <Label text="📋" style="-fx-font-size: 32px;"/>
            <Label text="Create Account"
                   style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
            <Label text="Choose Admin or Student"
                   style="-fx-text-fill: #9FE1CB; -fx-font-size: 12px;"/>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-background-color: #FAEEDA;
                     -fx-border-color: #854F0B;
                     -fx-border-width: 0 0 0 3;
                     -fx-padding: 10 16;">
            <Label text="⚠"
                   style="-fx-font-size: 14px; -fx-text-fill: #412402;"/>
            <Label text="Student accounts can view attendance only. Admin accounts can manage records."
                   style="-fx-font-size: 11px; -fx-text-fill: #633806;
                          -fx-wrap-text: true;" maxWidth="280"/>
        </HBox>

        <VBox spacing="12" style="-fx-padding: 20 28 8 28;">

            <VBox spacing="5">
                <Label text="ID"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444441;"/>
                <TextField fx:id="tfUsername" promptText="Minimum 3 characters"
                           style="-fx-font-size: 13px; -fx-padding: 9 12;
                                  -fx-border-color: #D3D1C7; -fx-border-radius: 6;
                                  -fx-background-radius: 6;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Full Name"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444441;"/>
                <TextField fx:id="tfFullName" promptText="Enter full name"
                           style="-fx-font-size: 13px; -fx-padding: 9 12;
                                  -fx-border-color: #D3D1C7; -fx-border-radius: 6;
                                  -fx-background-radius: 6;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Role"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444441;"/>
                <ComboBox fx:id="cbRole" promptText="Select role"
                          maxWidth="Infinity"
                          style="-fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Password"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444441;"/>
                <PasswordField fx:id="tfPassword" promptText="Minimum 6 characters"
                               style="-fx-font-size: 13px; -fx-padding: 9 12;
                                      -fx-border-color: #D3D1C7; -fx-border-radius: 6;
                                      -fx-background-radius: 6;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Confirm Password"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #444441;"/>
                <PasswordField fx:id="tfConfirm" promptText="Re-enter password"
                               style="-fx-font-size: 13px; -fx-padding: 9 12;
                                      -fx-border-color: #D3D1C7; -fx-border-radius: 6;
                                      -fx-background-radius: 6;"/>
            </VBox>

            <Label fx:id="lblError" text=""
                   style="-fx-text-fill: #A32D2D; -fx-font-size: 12px;
                          -fx-wrap-text: true;" maxWidth="304"/>
            <Label fx:id="lblSuccess" text=""
                   style="-fx-text-fill: #27500A; -fx-font-size: 12px;
                          -fx-wrap-text: true;" maxWidth="304"/>

            <Button text="Create Account" onAction="#handleRegister"
                    maxWidth="Infinity" prefHeight="40"
                    style="-fx-background-color: #2C2C2A; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-border-radius: 6; -fx-background-radius: 6;
                           -fx-cursor: hand;"/>
        </VBox>

        <HBox alignment="CENTER" spacing="4" style="-fx-padding: 14 28 22 28;">
            <Label text="Already have an account?"
                   style="-fx-font-size: 12px; -fx-text-fill: #888780;"/>
            <Hyperlink text="Sign in" onAction="#goToLogin"
                       style="-fx-font-size: 12px; -fx-text-fill: #185FA5;
                              -fx-border-color: transparent;"/>
        </HBox>

    </VBox>
</StackPane>
